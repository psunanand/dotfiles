# All the plugin files .sh must be chmod u+x
PLUGIN_DIR="$CONFIG_DIR/plugins"

# Load the color variables
source "$PLUGIN_DIR/colors.sh"

##### Bar Appearance #####
# Configuring the general appearance of the bar.
# For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# For color picker see:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker
bar=(
  height=36
  color=$BAR_COLOR
  shadow=on
  position=top
  sticky=on
  padding_left=10
  padding_right=10
  corner_radius=12
)
sketchybar --bar "${bar[@]}"

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
  drawing=on
  icon.font="SauceCodePro Nerd Font:Bold:16.0"
  label.font="SF pro:Semibold:14.0"
  icon.color=$ICON_COLOR
  label.color=$LABEL_COLOR

  # --- THE PILL GEOMETRY ---
  background.color=$ITEM_BG_COLOR
  background.corner_radius=15      # Rounded ends for the pill
  background.height=26             # Smaller than bar height (36) to float
  background.drawing=on            # Explicitly enable background drawing
  background.border_width=0        # No border

  # --- PADDING & SPACING ---
  icon.padding_left=10
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=10
  background.padding_left=5
  background.padding_right=5
)
sketchybar --default "${default[@]}"


##### Adding Mission Control Space Indicators #####
# Let's add some mission control spaces:
# https://felixkratz.github.io/SketchyBar/config/components#space----associate-mission-control-spaces-with-an-item
# to indicate active and available mission control spaces.

##### Adding Left Items #####
# We add some regular items to the left side of the bar, where
# only the properties deviating from the current defaults need to be set

# Add the aerospace_workspace_change event we specified in aerospace.toml
sketchybar --add event aerospace_workspace_change

for sid in {1..10}; do
    sketchybar --add item space.$sid left \
        --subscribe space.$sid aerospace_workspace_change \
        --set space.$sid \
            drawing=off \
            script="$CONFIG_DIR/plugins/aerospace.sh $sid" \
            click_script="aerospace workspace $sid" \
            icon.drawing=off \
            label="$sid" \
            label.padding_left=12 \
            label.padding_right=12

    for idx in 1 2 3; do
        sketchybar --add item space.$sid.app$idx left \
            --set space.$sid.app$idx \
                drawing=off \
                click_script="aerospace workspace $sid"
    done

    if [ "$sid" -lt 10 ]; then
        sketchybar --add item space.$sid.sep left \
            --set space.$sid.sep \
                drawing=off \
                icon="│" \
                icon.font="SF Pro:Semibold:14.0" \
                icon.color=$GREY \
                icon.padding_left=2 \
                icon.padding_right=2 \
                label.drawing=off \
                background.drawing=off
    fi
done

sketchybar --add item space_separator left \
  --set space_separator icon="􀆊" \
  icon.font="SF Pro:Heavy:18.0" \
  icon.color=$GREY \
  icon.padding_left=4 \
  label.drawing=off \
  background.drawing=off

sketchybar --add item front_app left \
           --set front_app \
           display=active \
           script="$PLUGIN_DIR/front_app.sh" \
           click_script="open -a 'Mission Control'" \
           --subscribe front_app front_app_switched

##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# Some items refresh on a fixed cycle, e.g. the clock runs its script once
# every 10s. Other items respond to events they subscribe to, e.g. the
# volume.sh script is only executed once an actual change in system audio
# volume is registered. More info about the event system can be found here:
# https://felixkratz.github.io/SketchyBar/config/events

sketchybar --add item clock right \
           --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh" \
           click_script="open -a Calendar" \
           --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
           click_script="open x-apple.systempreferences:com.apple.Sound-Settings.extension" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           click_script="open x-apple.systempreferences:com.apple.Battery-Settings.extension" \
           --subscribe battery system_woke power_source_change \
           --add item network right \
            --set network \
              update_freq=2 label.drawing=off script="$PLUGIN_DIR/network.sh" \
              popup.background.color=$POPUP_BACKGROUND_COLOR \
              popup.background.corner_radius=15 \
              popup.background.border_width=2 \
              popup.background.border_color=$ACCENT_COLOR \
              popup.blur_radius=0 \
              click_script="open x-apple.systempreferences:com.apple.Network-Settings.extension" \
            --subscribe network wifi_change mouse.entered mouse.exited system_woke \
            --add item network.popup.ssid popup.network \
            --set network.popup.ssid drawing=on \
              label.font="SF pro:Semibold:13.0" \
              label.color=$LABEL_COLOR \
              label.padding_left=12 \
              label.padding_right=12 \
              background.drawing=off \
            --add item network.popup.speed popup.network \
            --set network.popup.speed drawing=on \
              label.font="SF pro:Semibold:13.0" \
              label.color=$LABEL_COLOR \
              label.padding_left=12 \
              label.padding_right=12 \
              background.drawing=off \
           --add item usage right \
            --set usage \
              update_freq=10 label.drawing=off script="$PLUGIN_DIR/usage.sh" \
              popup.background.color=$POPUP_BACKGROUND_COLOR \
              popup.background.corner_radius=15 \
              popup.background.border_width=2 \
              popup.background.border_color=$ACCENT_COLOR \
              popup.blur_radius=0 \
              click_script="open -a 'Activity Monitor'" \
            --subscribe usage mouse.entered mouse.exited system_woke \
            --add item usage.popup.cpu popup.usage \
            --set usage.popup.cpu drawing=on \
              label.font="SF pro:Semibold:13.0" \
              label.color=$LABEL_COLOR \
              label.padding_left=12 \
              label.padding_right=12 \
              background.drawing=off \
            --add item usage.popup.ram popup.usage \
            --set usage.popup.ram drawing=on \
              label.font="SF pro:Semibold:13.0" \
              label.color=$LABEL_COLOR \
              label.padding_left=12 \
              label.padding_right=12 \
              background.drawing=off \
            --add item usage.popup.disk popup.usage \
            --set usage.popup.disk drawing=on \
              label.font="SF pro:Semibold:13.0" \
              label.color=$LABEL_COLOR \
              label.padding_left=12 \
              label.padding_right=12 \
              background.drawing=off


##### Force all scripts to run the first time  #####
sketchybar --update
